# Copier vers /opt/mini580/prod/.env (jamais committer les vrais secrets)
POSTGRES_USER=mini580
POSTGRES_PASSWORD=CHANGE_ME_PROD_DB_PASSWORD
POSTGRES_DB=mini580_prod

SESSION_SECRET=CHANGE_ME_PROD_SESSION_SECRET_MIN_32_CHARS_XXXX
EDITORS_ALLOWLIST=admin@classmini580.blog

# Rempli par deploy.sh
IMAGE=ghcr.io/mini580-baie-de-somme/mini-580:prod

# Media bucket: compose sets MEDIA_ROOT=/data/media + bind mount ./media
# Host path: /opt/mini580/prod/media (survives container redeploy)

# Telegram publication assistée IA (voir docs/09-telegram-publish.md)
SITE_URL=https://classmini580.blog
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_ALLOWED_USER_IDS=
# TELEGRAM_SERVICE_USER_EMAIL=admin@classmini580.blog
# INGEST_API_KEY=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Sync TEST ↔ PROD (OTP Ed25519)
SYNC_ENV=prod
SYNC_PEER_URL=https://test.classmini580.blog
SYNC_PRIVATE_KEY=
SYNC_PEER_PUBLIC_KEY=
