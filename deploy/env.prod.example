# Copier vers /opt/mini580/prod/.env (jamais committer les vrais secrets)
POSTGRES_USER=mini580
POSTGRES_PASSWORD=CHANGE_ME_PROD_DB_PASSWORD
POSTGRES_DB=mini580_prod

SESSION_SECRET=CHANGE_ME_PROD_SESSION_SECRET_MIN_32_CHARS_XXXX
EDITORS_ALLOWLIST=admin@classmini580.blog

# Rempli par deploy.sh
IMAGE=ghcr.io/mini580-baie-de-somme/mini-580:prod

# Sync TEST ↔ PROD (OTP Ed25519)
SYNC_ENV=prod
SYNC_PEER_URL=https://test.classmini580.blog
SYNC_PRIVATE_KEY=
SYNC_PEER_PUBLIC_KEY=
