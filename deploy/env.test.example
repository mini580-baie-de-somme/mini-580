# Copier vers /opt/mini580/test/.env (jamais committer les vrais secrets)
POSTGRES_USER=mini580
POSTGRES_PASSWORD=CHANGE_ME_TEST_DB_PASSWORD
POSTGRES_DB=mini580_test

SESSION_SECRET=CHANGE_ME_TEST_SESSION_SECRET_MIN_32_CHARS_XXXX
EDITORS_ALLOWLIST=admin@classmini580.blog
SEED_ADMIN_EMAIL=admin@classmini580.blog
SEED_ADMIN_PASSWORD=changeme123

# Rempli par deploy.sh
IMAGE=ghcr.io/mini580-baie-de-somme/mini-580:test

# Media bucket: compose sets MEDIA_ROOT=/data/media + bind mount ./media
# Host path: /opt/mini580/test/media (survives container redeploy)

# Sync TEST ↔ PROD (OTP Ed25519)
SYNC_ENV=test
SYNC_PEER_URL=https://classmini580.blog
# Multiline PEM: replace newlines with \n in .env
SYNC_PRIVATE_KEY=
SYNC_PEER_PUBLIC_KEY=
