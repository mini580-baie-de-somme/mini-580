generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Hull {
  HULL_268
  HULL_269
  HULL_270
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  posts        Post[]
}

model Post {
  id            String                   @id @default(cuid())
  slug          String                   @unique
  titleFr       String
  titleEn       String
  excerptFr     String                   @default("")
  excerptEn     String                   @default("")
  bodyFr        String                   @default("") @db.Text
  bodyEn        String                   @default("") @db.Text
  status        PostStatus               @default(DRAFT)
  authorId      String
  author        User                     @relation(fields: [authorId], references: [id])
  coverImageUrl String?
  publishedAt   DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  hulls         PostHull[]
  tags          PostTag[]
  themes        PostTheme[]
  milestones    PostMilestone[]
  images        PostImage[]
  telegramSessions TelegramPublishSession[]
  previewTokens PreviewToken[]
}

model PostHull {
  postId String
  hull   Hull
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, hull])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  labelFr   String
  labelEn   String
  createdAt DateTime  @default(now())
  posts     PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Theme {
  id     String      @id @default(cuid())
  slug   String      @unique
  labelFr String
  labelEn String
  posts  PostTheme[]
}

model PostTheme {
  postId  String
  themeId String
  post    Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  theme   Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([postId, themeId])
}

model Milestone {
  id            String          @id @default(cuid())
  slug          String          @unique
  titleFr       String
  titleEn       String
  descriptionFr String          @default("") @db.Text
  descriptionEn String          @default("") @db.Text
  milestoneDate DateTime
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  posts         PostMilestone[]
}

model PostMilestone {
  postId      String
  milestoneId String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@id([postId, milestoneId])
}

model PostImage {
  id            String    @id @default(cuid())
  postId        String
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// Original uploaded file (image_origine)
  urlOrigin     String
  urlPicto      String?
  urlPetite     String?
  urlMoyenne    String?
  urlGrande     String?
  titleFr       String    @default("")
  titleEn       String    @default("")
  descriptionFr String    @default("")
  descriptionEn String    @default("")
  takenAt       DateTime?
  sortOrder     Int       @default(0)
  /// Focus point 0–1 (object-position)
  focusX        Float     @default(0.5)
  focusY        Float     @default(0.5)
  zoom          Float     @default(1)
  /// Degrees: 0, 90, 180, 270
  rotation      Int       @default(0)
  /// Crop rectangle relative 0–1
  cropX         Float     @default(0)
  cropY         Float     @default(0)
  cropW         Float     @default(1)
  cropH         Float     @default(1)
}

enum TelegramSessionStep {
  AWAITING_CONTENT
  REVIEW_FR
  REVIEW_EN
  REVIEW_PREVIEW
  REVIEW_PHOTO_ORDER
  REVIEW_PHOTO_META_FR
  REVIEW_PHOTO_META_EN
  READY
  CANCELLED
  COMPLETED
}

/// Conversation state for Telegram-assisted publishing (authorized user IDs).
model TelegramPublishSession {
  id             String              @id @default(cuid())
  telegramUserId String
  telegramChatId String
  step           TelegramSessionStep @default(AWAITING_CONTENT)
  postId         String?
  post           Post?               @relation(fields: [postId], references: [id], onDelete: SetNull)
  /// Index into post.images during per-photo review
  photoIndex     Int                 @default(0)
  /// Pending media URLs + raw text before draft is created
  draftPayload   Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([telegramUserId, telegramChatId])
  @@index([step])
}

/// Durable Cursor agent thread per Telegram chat (free-form tools agent).
model TelegramAgentThread {
  id             String   @id @default(cuid())
  telegramUserId String
  telegramChatId String
  cursorAgentId  String?
  /// Post currently being created/edited by the agent (kept across turns)
  activePostId   String?
  /// Photo currently being created/edited by the agent
  activeImageId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([telegramUserId, telegramChatId])
}

/// Shareable draft preview link for Telegram (no login cookie).
model PreviewToken {
  id        String   @id @default(cuid())
  token     String   @unique
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([postId])
}

enum SyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SyncJobType {
  PULL_FROM_PROD
  PUBLISH_POST
  PUBLISH_MILESTONE
  CATALOG_PULL
  CATALOG_PUSH
}

/// Async TEST↔PROD sync job (global lock: only one PENDING/RUNNING at a time).
model SyncJob {
  id         String        @id @default(cuid())
  type       SyncJobType
  status     SyncJobStatus @default(PENDING)
  /// Job-specific params (postId, publish, direction, …)
  params     Json?
  /// { step, current, total, message, mediaSynced? }
  progress   Json?
  result     Json?
  error      String?       @db.Text
  createdBy  String?
  createdAt  DateTime      @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([status, createdAt])
}
