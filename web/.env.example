# PostgreSQL (local dev on port 5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini580?schema=public"

# Session signing secret (min 32 chars)
SESSION_SECRET="change-me-to-a-random-string-at-least-32-characters-long"

# Comma-separated emails allowed to log in and edit
EDITORS_ALLOWLIST="admin@classmini580.blog,laurent@example.com,marco@example.com,rodolphe@example.com"

# Seed admin user (created on `npx prisma db seed`)
SEED_ADMIN_EMAIL="admin@classmini580.blog"
SEED_ADMIN_PASSWORD="changeme123"

# Next.js dev server port (nginx proxies to this)
PORT=3002

# Local disk media bucket (S3-like API, no third-party service)
# Defaults to web/data/media if unset. On VPS: /data/media (bind mount).
# MEDIA_ROOT="./data/media"
# MEDIA_PUBLIC_BASE="/media"

# Public site URL (preview links sent on Telegram)
SITE_URL="http://localhost:3002"

# Machine auth for OpenClaw / Telegram bot (Bearer token, min 16 chars)
# INGEST_API_KEY="replace-with-a-long-random-secret"
# TELEGRAM_SERVICE_USER_EMAIL="admin@classmini580.blog"

# Telegram bot (webhook → /api/telegram/webhook)
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_WEBHOOK_SECRET=""
# Comma-separated numeric Telegram user IDs allowed to publish
# TELEGRAM_ALLOWED_USER_IDS="123456789,987654321"

# AI translation (OpenAI-compatible)
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"

# Sync TEST ↔ PROD (optional in local)
# SYNC_ENV=test
# SYNC_PEER_URL=https://classmini580.blog
# SYNC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# SYNC_PEER_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
