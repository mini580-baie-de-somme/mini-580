# PostgreSQL (local dev on port 5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini580?schema=public"

# Session signing secret (min 32 chars)
SESSION_SECRET="change-me-to-a-random-string-at-least-32-characters-long"

# Comma-separated emails allowed to log in and edit
EDITORS_ALLOWLIST="laurent@example.com,marco@example.com,rodolphe@example.com"

# Seed admin user (created on `npx prisma db seed`)
SEED_ADMIN_EMAIL="admin@cnbs.local"
SEED_ADMIN_PASSWORD="changeme123"

# Next.js dev server port (nginx proxies to this)
PORT=3001
