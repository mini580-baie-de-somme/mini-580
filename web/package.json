{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/bump-build.mjs",
    "build": "next build",
    "version:bump": "node scripts/bump-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "seed:run": "NODE_PATH=./node_modules tsx --env-file=.env ../prisma/seed.ts",
    "test:db:up": "docker compose -f docker-compose.test-db.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test-db.yml down",
    "test:db:migrate": "export $(grep -v '^#' .env.test | xargs) && npx prisma migrate deploy",
    "test:integration": "npm run test:local",
    "test": "npm run test:local",
    "test:local": "npm run test:db:up && npm run test:db:migrate && vitest run --config vitest.config.ts",
    "test:http": "vitest run --config vitest.http.config.ts",
    "test:telegram": "npm run test:db:up && npm run test:db:migrate && vitest run --config vitest.telegram.config.ts",
    "test:cursor:sync": "bash ../scripts/sync-cursor-key-from-vps.sh"
  },
  "prisma": {
    "seed": "npm run seed:run"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "15.5.20",
    "pg": "^8.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
