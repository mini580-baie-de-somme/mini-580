{
  "$schema": "https://docs.openclaw.ai/schemas/openclaw.schema.json",
  "_comment": "Configuration conceptuelle Class Mini 5.80 Baie de Somme — à adapter avec vos vrais IDs Telegram",

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["<ADMIN_TELEGRAM_USER_ID>"],
      "groups": {
        "<MINI580_CHANTIER_GROUP_ID>": {
          "requireMention": false,
          "groupPolicy": "allowlist",
          "groupAllowFrom": [
            "<LAURENT_TELEGRAM_USER_ID>",
            "<MARCO_TELEGRAM_USER_ID>",
            "<RODOLPHE_TELEGRAM_USER_ID>",
            "<ADMIN_TELEGRAM_USER_ID>"
          ]
        }
      }
    }
  },

  "agents": {
    "list": [
      {
        "id": "mini580-admin",
        "name": "Class Mini 5.80 Admin",
        "workspace": "./workspace/admin",
        "skills": ["mini580-publish", "mini580-migrate", "mini580-deploy"]
      },
      {
        "id": "mini580-publisher",
        "name": "Class Mini 5.80 Publisher",
        "workspace": "./workspace/publisher",
        "skills": ["mini580-ingest", "mini580-publish-review", "mini580-draft", "mini580-class-checklist"]
      }
    ]
  },

  "skills": {
    "load": {
      "extraDirs": ["./openclaw/skills"]
    }
  },

  "cron": {
    "jobs": [
      {
        "name": "mini580-drive-watch",
        "schedule": "*/15 * * * *",
        "agent": "mini580-publisher",
        "message": "Vérifie le dossier Google Drive Class Mini 5.80 Baie de Somme/À publier pour de nouveaux fichiers"
      }
    ]
  }
}
